-- サービス取得
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- 機能の状態管理
local settings = {
    speedEnabled = false,
    speedValue = 50,
    tpWalkEnabled = false,
    infiniteJumpEnabled = false,
    originalWalkSpeed = humanoid.WalkSpeed
}

-- TP Walk用変数
local tpWalkConnection = nil
local lastPosition = nil

-- 無限ジャンプ用変数
local infiniteJumpConnection = nil

-- Orion UIライブラリの読み込み
local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/jadpy/suki/refs/heads/main/orion"))()

-- ウィンドウ作成
local Window = OrionLib:MakeWindow({
    Name = "The Master of the Tsunami HUB",
    HidePremium = false,
    SaveConfig = true,
    ConfigFolder = "TsunamiHUB"
})

-- メインタブ
local MainTab = Window:MakeTab({
    Name = "Movement",
    Icon = "rbxassetid://4483345998",
    PremiumOnly = false
})

-- Speedセクション
local SpeedSection = MainTab:AddSection({
    Name = "Speed"
})

local SpeedToggle = MainTab:AddToggle({
    Name = "Enable Speed",
    Default = false,
    Callback = function(Value)
        settings.speedEnabled = Value
        if Value then
            humanoid.WalkSpeed = settings.speedValue
        else
            humanoid.WalkSpeed = settings.originalWalkSpeed
        end
    end
})

local SpeedSlider = MainTab:AddSlider({
    Name = "Speed Value",
    Min = 16,
    Max = 500,
    Default = 50,
    Color = Color3.fromRGB(0, 150, 255),
    Increment = 1,
    ValueName = "Walkspeed",
    Callback = function(Value)
        settings.speedValue = Value
        if settings.speedEnabled then
            humanoid.WalkSpeed = Value
        end
    end
})

-- TP Walkセクション
local TpWalkSection = MainTab:AddSection({
    Name = "TP Walk"
})

local TpWalkToggle = MainTab:AddToggle({
    Name = "Enable TP Walk",
    Default = false,
    Callback = function(Value)
        settings.tpWalkEnabled = Value
        if Value then
            lastPosition = rootPart.Position
            tpWalkConnection = RunService.RenderStepped:Connect(function()
                if settings.tpWalkEnabled and character and character.Parent then
                    local currentPos = rootPart.Position
                    local distance = (currentPos - lastPosition).Magnitude
                    
                    if distance > 2 then
                        rootPart.CFrame = CFrame.new(lastPosition + (currentPos - lastPosition).Unit * 2, rootPart.Position + rootPart.CFrame.LookVector)
                    end
                    lastPosition = rootPart.Position
                end
            end)
        else
            if tpWalkConnection then
                tpWalkConnection:Disconnect()
                tpWalkConnection = nil
            end
        end
    end
})

-- 無限ジャンプセクション
local JumpSection = MainTab:AddSection({
    Name = "Jump"
})

local InfiniteJumpToggle = MainTab:AddToggle({
    Name = "Enable Infinite Jump",
    Default = false,
    Callback = function(Value)
        settings.infiniteJumpEnabled = Value
        if Value then
            infiniteJumpConnection = UserInputService.JumpRequest:Connect(function()
                if settings.infiniteJumpEnabled and character and character.Parent then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end)
        else
            if infiniteJumpConnection then
                infiniteJumpConnection:Disconnect()
                infiniteJumpConnection = nil
            end
        end
    end
})

