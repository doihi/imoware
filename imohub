local function StartPacketLagDetector()
    local GE = ReplicatedStorage:WaitForChild("GrabEvents")
    GE:WaitForChild("ExtendGrabLine").OnClientEvent:Connect(function(arg1, data)
        if typeof(data) == "string" and not lastLagSource and packetLagNotifyEnabled then
            if string.len(data) > 300 then
                lastLagSource = true
                Library:Notify("PACKET LAG DETECTED\nSource: " .. tostring(arg1):sub(1, 20), 5)
                task.delay(5, function() lastLagSource = false end)
            end
        end
    end)
end
